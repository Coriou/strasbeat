{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/(shareimage\\.png|favicon\\.(svg|ico)|favicon-.*\\.png|apple-touch-icon\\.png)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/strudel-cc/:path*",
      "destination": "https://strudel.cc/:path*"
    }
  ]
}
